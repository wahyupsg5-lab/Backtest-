[Unit]
Description=SMC Trading Bot (bott_v4.py)
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/Claudebuattrade
Environment=API_KEY=GANTI_API_KEY
Environment=API_SECRET=GANTI_API_SECRET
Environment=TESTNET=false
Environment=PORT=8080
ExecStart=/usr/bin/python3 /home/ubuntu/Claudebuattrade/bott_v4.py
Restart=always
RestartSec=15

[Install]
WantedBy=multi-user.target
